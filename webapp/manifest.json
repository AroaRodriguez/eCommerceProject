{
  "_version": "1.83.0",
  "sap.app": {
    "id": "ecommerceproject",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.21.0",
      "toolsId": "40b383b0-8b49-4e40-8458-abc8f2a488d9"
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "fullWidth": true,
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.146.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.f": {},
        "sap.ui.layout": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "ecommerceproject.i18n.i18n"
        }
      },
      "configModel": {
        "type": "sap.ui.model.json.JSONModel",
        "uri": "model/config.json"
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "controlAggregation": "pages",
        "controlId": "app",
        "transition": "slide",
        "type": "View",
        "viewType": "XML",
        "path": "ecommerceproject.view",
        "async": true,
        "viewPath": "ecommerceproject.view"
      },
      "routes": [
        {
          "name": "RouteHome",
          "pattern": ":?query:",
          "target": [
            "TargetHome"
          ]
        },
        {
          "name": "RouteDetail",
          "pattern": "detail/{productIndex}",
          "target": [
            "TargetDetail"
          ]
        }
      ],
      "targets": {
        "TargetHome": {
          "viewType": "XML",
          "viewName": "Home",
          "id": "Home"
        },
        "TargetDetail": {
          "viewType": "XML",
          "viewName": "Detail",
          "id": "Detail"
        }
      }
    },
    "rootView": {
      "viewName": "ecommerceproject.view.App",
      "type": "XML",
      "id": "App",
      "async": true
    }
  }
}